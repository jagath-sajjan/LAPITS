#!/usr/bin/env bash

set -euo pipefail

# deps check fr
check_deps() {
  local deps=("gum" "jq" "curl" "sqlite3")
  local missing=()

  for dep in "${deps[@]}"; do
    if ! command -v "$dep" > /dev/null 2>&1; then
        missing+=("$dep")
    fi
  done

  if [ ${#missing[@]} -ne 0 ]; then
    echo "Missing Dependencies: ${missing[*]}"
    echo ""
    echo "Install with:"
    echo " brew install gum jq sqlite3 curl # macOS"
    echo " sudo apt install jq curl sqlite3 # Debian/Ubuntu"
    exit 1
  fi
}

check_deps

# Source Libs (To Be Created Nxt)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
LIB_DIR="$ROOT_DIR/lib"
DATA_DIR="$ROOT_DIR/data"
CONFIG_DIR="$ROOT_DIR/config"

mkdir -p \
  "$DATA_DIR/collections" \
  "$DATA_DIR/environments" \
  "$DATA_DIR/history" \
  "$DATA_DIR/tmp" \
  "$DATA_DIR/templates"

# Shellcheck's source=/dev/null
source "$LIB_DIR/core/variables.sh"
source "$LIB_DIR/core/auth.sh"
source "$LIB_DIR/core/http.sh"
source "$LIB_DIR/core/curl_import.sh"
source "$LIB_DIR/ui/request_builder.sh"

# Main Men-u
main_menu() {
  while true; do
    clear 

  gum style \
      --border double \
      --align center \
      --width 50 \
      --margin "1 2" \
      --padding "2 4" \
      'LAPITS' 'API Test-ting & Mock Server'
  
  local CHOICE
  CHOICE=$(gum choose \
      "New Req" \
      "Collections" \
      "Environments" \
      "History" \
      "Mock Server" \
      "Setting" \
      "EXIT")
  
  case "$CHOICE" in
      "New Req") new_request ;;
      "Collections") collection_menu ;;
      "Environments") environments_menu ;;
      "History") history_menu ;;
      "Mock Server") mock_server_menu ;;
      "Settings") settings_menu ;;
      "EXIT") exit 0 ;;
    esac
  done 
}

# Just Empaty Func's
new_request() {
  lapits_request_builder
}

collection_menu() {
  gum style --border rounded --padding "1 2" "Coming Soon: Collections"
  gum input --placeholder "Press entor to continue..." >/dev/null  
}

environments_menu() {
  lapits_environment_menu
}

history_menu() {
  gum style --border rounded --padding "1 2" "Coming Soon: History"
  gum input --placeholder "Press entor to continue..." >/dev/null  
}

mock_server_menu() {
  gum style --border rounded --padding "1 2" "Coming Soon: Mock Server"
  gum input --placeholder "Press entor to continue..." >/dev/null
}

settings_menu() {
  gum style --border rounded --padding "1 2" "Coming Soon: Settings"
  gum input --placeholder "Press entor to continue..." >/dev/null
}

main_menu
